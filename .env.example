# LLM provider (xAI - Grok)
# Required for Phase 4 (LLM recommendations).
XAI_API_KEY=

# Optional: override base URL
XAI_BASE_URL=https://api.x.ai/v1

# Optional: model name
XAI_MODEL=grok-beta

# Optional: request tuning (reasonable defaults; adjust later)
XAI_TIMEOUT_SECONDS=30
XAI_MAX_TOKENS=600
XAI_TEMPERATURE=0.3

# Hugging Face dataset configuration (Phase 1)
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation
HF_DATASET_REVISION=

# Optional: Hugging Face cache directory override
HF_DATASET_CACHE_DIR=

# Optional: Hugging Face token (helps with rate limits)
HF_TOKEN=

# Optional (Windows): disable symlink limitation warning
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Candidate cap for LLM context (Phase 3)
CANDIDATE_CAP=25

